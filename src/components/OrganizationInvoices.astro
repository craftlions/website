---
import { getUuidV7Date } from "../lib/uuid.ts";
import InvoiceTable from "./InvoiceTable.astro";

interface Props {
	id: string;
}

const { id } = Astro.props;

const organization = await Astro.locals.db.query.organization.findFirst({
	columns: {
		id: true,
	},
	with: {
		projects: {
			columns: {
				id: true,
			},
			with: {
				phases: {
					columns: {},
					with: {
						invoice: {
							columns: {
								id: true,
								invoiceNumber: true,
								stripePaymentPage: true,
							},
						},
					},
				},
			},
		},
	},
	where: {
		id,
	},
});

const invoices = (organization?.projects ?? [])
	.flatMap((project) => project.phases)
	.flatMap((phase) => (phase.invoice ? [phase.invoice] : []))
	.map((invoice) => ({
		invoiceNumber: invoice.invoiceNumber,
		stripePaymentPage: invoice.stripePaymentPage,
		createdAt: getUuidV7Date(invoice.id),
	}))
	.toSorted(
		(a, b) => (b.createdAt?.getTime() ?? 0) - (a.createdAt?.getTime() ?? 0),
	);
---

<InvoiceTable invoices={invoices} />
