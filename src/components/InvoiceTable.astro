---
import Button from "./Button.astro";

interface Invoice {
	invoiceNumber: string;
	stripePaymentPage: string;
	createdAt: Date;
}

interface Props {
	invoices: Invoice[];
	pageSize?: number;
}

const { invoices, pageSize = 5 } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("de-DE", { dateStyle: "medium" });
---

<invoice-table class="grid gap-3" data-page-size={pageSize}>
	{invoices.length > 0 ? (
			<div class="overflow-x-auto border border-dashed border-neutral-300 dark:border-neutral-700">
				<table class="w-full min-w-xl text-left text-sm">
					<thead>
						<tr class="border-b border-dashed border-neutral-300 text-neutral-500 dark:border-neutral-700 dark:text-neutral-400">
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">Created At</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">Invoice Number</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">Payment Link</th>
						</tr>
					</thead>
					<tbody>
						{invoices.map((invoice) => (
								<tr class="border-b border-dashed border-neutral-300 last:border-b-0 dark:border-neutral-700">
									<td class="px-4 py-3">
										{dateFormatter.format(new Date(invoice.createdAt))}
									</td>
									<td class="px-4 py-3">{invoice.invoiceNumber}</td>
									<td class="px-4 py-3">
										<Button
											href={invoice.stripePaymentPage}
											target="_blank"
											rel="noopener noreferrer"
										>
											Details
										</Button>
									</td>
								</tr>
							))}
					</tbody>
				</table>
			</div>
		) : (
			<p class="border border-dashed border-neutral-300 bg-transparent p-4 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
				No invoices yet.
			</p>
		)}
	<nav
		aria-label="Invoice pagination"
		class="grid grid-cols-[auto_1fr_auto] items-center gap-3 text-sm"
		data-invoice-pagination="controls"
		hidden
	>
		<Button type="button" data-invoice-pagination="previous">Previous</Button>
		<output
			aria-live="polite"
			class="text-center text-neutral-600 dark:text-neutral-400"
			data-invoice-pagination="status"
		></output>
		<Button type="button" data-invoice-pagination="next">Next</Button>
	</nav>
</invoice-table>

<script>
	class InvoiceTable extends HTMLElement {
		page = 1;

		connectedCallback() {
			if (this.dataset.initialized === "true") {
				this.renderPage();
				return;
			}

			this.dataset.initialized = "true";
			this.querySelector(
				'[data-invoice-pagination="previous"]',
			)?.addEventListener("click", () => {
				this.page -= 1;
				this.renderPage();
			});
			this.querySelector('[data-invoice-pagination="next"]')?.addEventListener(
				"click",
				() => {
					this.page += 1;
					this.renderPage();
				},
			);
			this.renderPage();
		}

		renderPage() {
			const rows = Array.from(
				this.querySelectorAll<HTMLTableRowElement>("tbody tr"),
			);
			const parsed = Number(this.dataset.pageSize);
			const pageSize = Math.max(1, Number.isFinite(parsed) ? parsed : 5);
			const pageCount = Math.ceil(rows.length / pageSize);
			const controls = this.querySelector<HTMLElement>(
				'[data-invoice-pagination="controls"]',
			);
			const previousButton = this.querySelector<HTMLButtonElement>(
				'[data-invoice-pagination="previous"]',
			);
			const nextButton = this.querySelector<HTMLButtonElement>(
				'[data-invoice-pagination="next"]',
			);
			const status = this.querySelector<HTMLElement>(
				'[data-invoice-pagination="status"]',
			);

			if (!controls || !previousButton || !nextButton || !status) {
				return;
			}

			if (pageCount <= 1) {
				for (const row of rows) {
					row.hidden = false;
				}

				controls.hidden = true;
				return;
			}

			this.page = Math.min(Math.max(this.page, 1), pageCount);
			controls.hidden = false;

			for (const [index, row] of rows.entries()) {
				row.hidden =
					index < (this.page - 1) * pageSize || index >= this.page * pageSize;
			}

			previousButton.disabled = this.page === 1;
			nextButton.disabled = this.page === pageCount;
			status.textContent = `Page ${this.page} of ${pageCount}`;
		}
	}

	customElements.define("invoice-table", InvoiceTable);
</script>
