---
interface Props {
	date: string;
	datetime: string;
	title: string;
	summary: string;
	points?: string[];
}

const { date, datetime, title, summary, points = [] } = Astro.props;
---

<li class="grid grid-cols-[1rem_1fr] gap-x-4">
	<div class="grid justify-items-center" aria-hidden="true">
		<span
			class="mt-2 h-2 w-2 border border-neutral-500 bg-transparent dark:border-neutral-400"
		></span>
		<span
			class="min-h-20 border-l border-dashed border-neutral-300 dark:border-neutral-700"
		></span>
	</div>
	<article
		class="grid gap-4 border border-dashed border-neutral-300 bg-transparent p-4 pb-10 dark:border-neutral-700"
	>
		<header class="grid gap-2">
			<time
				datetime={datetime}
				class="text-sm font-semibold text-neutral-500 dark:text-neutral-400"
			>
				{date}
			</time>
			<h2 class="text-2xl font-semibold">{title}</h2>
		</header>
		<p class="text-neutral-700 dark:text-neutral-300">{summary}</p>
		{points.length > 0 && (
				<ul class="grid gap-2 text-sm text-neutral-700 dark:text-neutral-300">
					{points.map((point) => (
						<li class="grid grid-cols-[auto_1fr] gap-2">
							<span class="text-neutral-500 dark:text-neutral-400" aria-hidden="true">
								*
							</span>
							<span>{point}</span>
						</li>
					))}
				</ul>
			)}
	</article>
</li>
