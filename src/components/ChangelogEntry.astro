---
interface Props {
	date: string;
	datetime: string;
	title: string;
	summary: string;
	points?: string[];
}

const { date, datetime, title, summary, points = [] } = Astro.props;
---

<li class="grid grid-cols-[1rem_1fr] gap-x-4">
	<div class="grid justify-items-center" aria-hidden="true">
		<span
			class="mt-2 h-3 w-3 rounded-full bg-cyan-500 ring-4 ring-cyan-100 dark:ring-cyan-950"
		></span>
		<span class="w-px min-h-20 bg-neutral-200 dark:bg-neutral-800"></span>
	</div>
	<article
		class="grid gap-4 pb-10 border border-dashed border-neutral-200 dark:border-neutral-800 p-4 bg-neutral-100/60 dark:bg-neutral-900/60"
	>
		<header class="grid gap-2">
			<time
				datetime={datetime}
				class="text-sm font-semibold text-cyan-700 dark:text-cyan-400"
			>
				{date}
			</time>
			<h2 class="text-2xl font-extrabold">{title}</h2>
		</header>
		<p class="text-neutral-700 dark:text-neutral-300">{summary}</p>
		{points.length > 0 && (
				<ul class="grid gap-2 text-sm text-neutral-700 dark:text-neutral-300">
					{points.map((point) => (
						<li class="grid grid-cols-[auto_1fr] gap-2">
							<span class="text-cyan-700 dark:text-cyan-400" aria-hidden="true">
								*
							</span>
							<span>{point}</span>
						</li>
					))}
				</ul>
			)}
	</article>
</li>
