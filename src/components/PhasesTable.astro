---
import type { phaseSelectType } from "../lib/schema";
import { actions } from "astro:actions";
import Badge from "./Badge.astro";
import Button from "./Button.astro";

interface Phase {
	publicId: phaseSelectType["publicId"];
	title: phaseSelectType["title"];
	dueAt: phaseSelectType["dueAt"];
	cost: phaseSelectType["cost"];
	currency: phaseSelectType["currency"];
	state: phaseSelectType["state"];
	externalUrl: phaseSelectType["externalUrl"];
}

interface Props {
	phases: Phase[];
}

const { phases } = Astro.props;
const dateFormatter = new Intl.DateTimeFormat("de-DE", { dateStyle: "medium" });

const phaseStateToBadgeType = (phaseState: phaseSelectType["state"]) => {
	switch (phaseState) {
		case "submitted":
		case "planned":
		case "approved":
		case "in_progress":
		case "invoiced":
			return "info";
		case "paid":
			return "success";
		case "cancelled":
			return "error";
		default:
			return "info";
	}
};
---

<div class="grid gap-3">
	{phases.length > 0 ? (
			<div class="overflow-x-auto border border-dashed border-neutral-300 bg-transparent dark:border-neutral-700">
				<table class="w-full min-w-2xl border-collapse text-left text-sm">
					<thead>
						<tr class="border-b border-dashed border-neutral-300 text-neutral-500 dark:border-neutral-700 dark:text-neutral-400">
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">
								Title
							</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">
								Due Date
							</th>
							<th
								scope="col"
								class="px-4 py-3 text-right text-xs font-semibold uppercase"
							>
								Cost
							</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">
								State
							</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">
								Link
							</th>
							<th scope="col" class="px-4 py-3 text-xs font-semibold uppercase">
								Actions
							</th>
						</tr>
					</thead>
					<tbody>
						{phases.map((phase) => (
							<tr class="border-b border-dashed border-neutral-300 transition-colors last:border-b-0 hover:bg-neutral-100/70 dark:border-neutral-700 dark:hover:bg-neutral-900/70">
								<td class="px-4 py-4 font-medium text-neutral-900 dark:text-neutral-100">
									{phase.title}
								</td>
								<td class="whitespace-nowrap px-4 py-4 text-neutral-700 dark:text-neutral-300">
									{phase.dueAt
										? dateFormatter.format(phase.dueAt)
										: "Not scheduled"}
								</td>
								<td class="whitespace-nowrap px-4 py-4 text-right tabular-nums text-neutral-700 dark:text-neutral-300">
									{new Intl.NumberFormat("de-DE", {
										style: "currency",
										currency: phase.currency,
									}).format(phase.cost)}
								</td>
								<td class="px-4 py-4">
									<Badge type={phaseStateToBadgeType(phase.state)}>
										{phase.state.replaceAll("_", " ")}
									</Badge>
								</td>
							<td class="px-4 py-4">
								{phase.externalUrl && (
									<a
										href={phase.externalUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="inline-flex h-8 w-8 items-center justify-center rounded-md text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100"
										aria-label="Open external link"
									>
										<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><g class="nrj6pi"><path class="yzskvq"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.5s" values="42;0"/></path><path stroke-dashoffset="12" class="zpa20g"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.5s" dur="0.2s" to="0"/></path><path stroke-dashoffset="8" class="p05a6a"><animate fill="freeze" attributeName="stroke-dashoffset" begin="0.7s" dur="0.2s" to="0"/></path></g></svg>
									</a>
								)}
							</td>
							<td class="px-4 py-4">
								{phase.state === "planned" && (
									<div class="grid grid-flow-col justify-start gap-2">
										<form method="POST" action={actions.approvePhase}>
											<input
												type="hidden"
												name="phaseId"
												value={phase.publicId}
											/>
											<Button type="submit">Approve</Button>
										</form>
										<form method="POST" action={actions.declinePhase}>
											<input
												type="hidden"
												name="phaseId"
												value={phase.publicId}
											/>
											<Button type="submit">Decline</Button>
										</form>
									</div>
								)}
							</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		) : (
			<p class="border border-dashed border-neutral-300 bg-transparent p-4 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
				No phases have been added yet.
			</p>
		)}
</div>

<style>
	.nrj6pi {
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: var(--svg-stroke-width--2px, 2px);
	}

	.p05a6a {
		stroke-dasharray: 8;
		d: path("M21 3h-6M21 3v6");
	}

	.yzskvq {
		stroke-dasharray: 42;
		d: path("M11 5h-6v14h14v-6");
	}

	.zpa20g {
		stroke-dasharray: 12;
		d: path("M13 11l7 -7");
	}
</style>
