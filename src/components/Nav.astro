---
import LogoWithTextVertical from "../assets/logoWithTextVertical.svg";
import NavSessionLinks from "./NavSessionLinks.astro";

interface Props {
	deferSessionLinks?: boolean;
	organizationSlug?: string | undefined;
	variant?: "app" | "marketing";
}

const {
	deferSessionLinks = false,
	organizationSlug,
	variant = "app",
} = Astro.props;
---

<nav
	aria-label="Primary"
	class="grid w-full grid-cols-1 gap-4 py-4 justify-items-center sm:grid-cols-[auto_1fr] sm:items-center"
>
	<a
		href="/"
		aria-label="craftlions home"
		class="grid justify-self-center sm:justify-self-start"
	>
		<LogoWithTextVertical
			class:list={[
				"[view-transition-name:nav-logo]",
				variant === "marketing" ? "h-24" : "h-9",
			]}
		/>
	</a>
	<ul
		class="grid grid-flow-col auto-cols-max items-center gap-2 max-w-full overflow-x-auto justify-self-center text-sm sm:justify-self-end"
	>
		{deferSessionLinks ? (
				<NavSessionLinks organizationSlug={organizationSlug} server:defer>
					<li slot="fallback">
						<span class="inline-grid w-max border border-dashed border-neutral-300 px-3 py-1 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
							Loading...
						</span>
					</li>
				</NavSessionLinks>
			) : (
				<NavSessionLinks organizationSlug={organizationSlug} />
			)}
	</ul>
</nav>
