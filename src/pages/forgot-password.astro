---
export const prerender = false;

import Button from "../components/Button.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Shell from "../layouts/Shell.astro";

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (session) {
	return Astro.redirect("/");
}
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Forgot Password</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-12 p-4 text-pretty"
		>
			<header class="grid gap-6 justify-items-center max-w-3xl mx-auto">
				<Nav variant="marketing" />
			</header>

			<main class="w-full grid content-start min-h-0 max-w-lg mx-auto gap-6">
				<h1
					class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
				>
					Reset password
				</h1>
				<p class="text-neutral-600 dark:text-neutral-400 text-sm">
					Enter your email address and we'll send you a link to reset your
					password.
				</p>
				<form
					id="forgot-form"
					class="grid gap-6"
					aria-label="Forgot password form"
				>
					<fieldset class="grid gap-4 border-none p-0 m-0">
						<div class="grid gap-1.5">
							<label
								for="email"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Email address
							</label>
							<input
								type="email"
								id="email"
								name="email"
								autocomplete="email"
								required
								placeholder="you@example.com"
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 text-sm outline-none transition-colors placeholder:text-neutral-400 focus:border-neutral-600 dark:border-neutral-700 dark:placeholder:text-neutral-600 dark:focus:border-neutral-300"
							>
						</div>
					</fieldset>

					<Button type="submit" id="forgot-submit"> Send reset link </Button>
				</form>

				<p
					id="forgot-message"
					class="text-sm hidden"
					role="status"
					aria-live="polite"
				> </p>

				<a
					href="/login"
					class="justify-self-start text-sm text-sky-700 underline decoration-dashed underline-offset-4 dark:text-sky-300"
				>
					Back to sign in
				</a>
			</main>

			<Footer />
		</body>
	</Fragment>
</Shell>

<script>
	import { authClient } from "../lib/auth-client";

	const form = document.getElementById("forgot-form") as HTMLFormElement;
	const submitBtn = document.getElementById(
		"forgot-submit",
	) as HTMLButtonElement;
	const message = document.getElementById(
		"forgot-message",
	) as HTMLParagraphElement;

	form.addEventListener("submit", async (event) => {
		event.preventDefault();

		const data = new FormData(form);
		const email = (data.get("email") as string).trim();

		if (!email) {
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = "Sending…";

		const { error } = await authClient.requestPasswordReset({
			email,
			redirectTo: `${window.location.origin}/reset-password`,
		});

		if (error) {
			submitBtn.disabled = false;
			submitBtn.textContent = "Send reset link";
			message.textContent =
				error.message || "Something went wrong. Please try again.";
			message.className = "text-sm text-red-600 dark:text-red-400";
		} else {
			form.reset();
			submitBtn.textContent = "Sent";
			message.textContent =
				"If an account exists for that email, you'll receive a reset link shortly.";
			message.className = "text-sm text-green-700 dark:text-green-400";
		}
	});
</script>
