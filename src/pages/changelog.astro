---
export const prerender = true;

import ChangelogEntry from "../components/ChangelogEntry.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Shell from "../layouts/Shell.astro";

const entries: {
	date: string;
	datetime: string;
	title: string;
	kind: "New" | "Improved" | "Fixed";
	summary: string;
	points?: string[];
}[] = [
	{
		date: "June 3, 2026",
		datetime: "2026-06-03",
		title: "Completed projects",
		kind: "Improved",
		summary:
			"Keep the project list focused on active work — completed projects can be set aside without losing their history.",
		points: [
			"Completed projects appear dimmed in the organization project list.",
			"A new toggle hides completed projects from the list.",
		],
	},
	{
		date: "April 30, 2026",
		datetime: "2026-04-30",
		title: "Budgets",
		kind: "New",
		summary:
			"Track costs against a set budget, with remaining budget visible at a glance.",
	},
	{
		date: "April 29, 2026",
		datetime: "2026-04-29",
		title: "Phases",
		kind: "New",
		summary:
			"Follow project progress by phase, including the costs tied to each stage.",
		points: ["Organization and project pages can show related phases."],
	},
	{
		date: "April 28, 2026",
		datetime: "2026-04-28",
		title: "Invoices",
		kind: "New",
		summary:
			"Billing is easier to verify, with invoice history now visible in client workspaces.",
		points: ["Organization and project pages can show related invoices."],
	},
];
---

<Shell>
	<Fragment slot="head">
		<title>craftlions | Changelog</title>
		<meta
			name="description"
			content="Review the latest craftlions website updates, product improvements, and platform changes."
		>
		<meta property="og:title" content="craftlions | Changelog">
		<meta
			property="og:description"
			content="A timeline of the latest craftlions website and platform updates."
		>
		<meta property="og:type" content="website">
	</Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav deferSessionLinks />
			</header>

			<main class="w-full grid content-start min-h-0 max-w-3xl mx-auto gap-8">
				<section class="grid gap-4">
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight text-balance dark:border-neutral-600"
					>
						Changelog
					</h1>
					<p class="max-w-2xl text-neutral-700 dark:text-neutral-300">
						A timeline of improvements, fixes, and visible updates to the
						craftlions website.
					</p>
				</section>

				<ol class="grid" aria-label="Website update timeline">
					{entries.map((entry, index) => (
							<ChangelogEntry
								date={entry.date}
								datetime={entry.datetime}
								title={entry.title}
								kind={entry.kind}
								summary={entry.summary}
								points={entry.points ?? []}
								first={index === 0}
								last={index === entries.length - 1}
							/>
						))}
				</ol>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
