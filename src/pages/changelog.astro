---
export const prerender = true;

import ChangelogEntry from "../components/ChangelogEntry.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import Shell from "../layouts/Shell.astro";

const entries = [
	{
		date: "May 9, 2026",
		datetime: "2026-05-09",
		title: "API",
		summary:
			"We introduced a new API for managing projects, phases, budgets, and invoices, enabling better integration with external tools and custom workflows.",
		points: [
			"The API allows for creating, updating, and retrieving project details, phases, budgets, and invoices programmatically.",
			"API Keys can be generated in the user dashboard for secure access to the API.",
		],
	},
	{
		date: "May 3, 2026",
		datetime: "2026-05-03",
		title: "Event Log",
		summary:
			"The latest website update introduces an event log for project pages, making project and milestone changes easier to review in one place.",
		points: [
			"Project pages can show a unified timeline of project and milestone updates.",
		],
	},
	{
		date: "April 30, 2026",
		datetime: "2026-04-30",
		title: "Budgets",
		summary:
			"The latest website update introduces budget tracking, allowing better visibility into costs and remaining budget.",
	},
	{
		date: "April 29, 2026",
		datetime: "2026-04-29",
		title: "Phases",
		summary:
			"The latest website update introduces phase tracking for projects, allowing better visibility into project progress and associated costs.",
		points: ["Organization and project pages can show related phases."],
	},
	{
		date: "April 28, 2026",
		datetime: "2026-04-28",
		title: "Invoices",
		summary:
			"The latest website update introduces invoice visibility for customer workspaces, making billing details easier to review alongside organizations and projects.",
		points: ["Organization and project pages can show related invoices."],
	},
];
---

<Shell>
	<Fragment slot="head">
		<title>craftlions | Changelog</title>
		<meta
			name="description"
			content="Follow the latest craftlions website updates, product improvements, and platform changes."
		>
		<meta property="og:title" content="craftlions | Changelog">
		<meta
			property="og:description"
			content="A timeline of the latest craftlions website and platform updates."
		>
		<meta property="og:type" content="website">
	</Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav deferSessionLinks />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-8"
			>
				<section class="grid gap-4">
					<p
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Website updates
					</p>
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						Changelog
					</h1>
					<p class="max-w-2xl text-neutral-700 dark:text-neutral-300">
						A concise timeline of improvements, fixes, and visible product
						updates across the craftlions website.
					</p>
				</section>

				<ol class="grid gap-4" aria-label="Website update timeline">
					{entries.map((entry) => (
							<ChangelogEntry
								date={entry.date}
								datetime={entry.datetime}
								title={entry.title}
								summary={entry.summary}
								points={entry.points ?? []}
							/>
						))}
				</ol>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
