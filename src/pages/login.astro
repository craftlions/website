---
export const prerender = false;

import LogoWithTextVertical from "../assets/logoWithTextVertical.svg";
import Footer from "../components/Footer.astro";
import Shell from "../layouts/Shell.astro";

const session = await Astro.locals.auth.api.getSession({
	headers: await Astro.request.headers,
});

if (session) {
	return Astro.redirect("/");
}
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Login</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-12 p-4 text-pretty"
		>
			<header class="grid gap-6 justify-items-center max-w-3xl mx-auto">
				<nav class="py-6 grid grid-cols-1 w-full">
					<LogoWithTextVertical
						class="h-28"
						style="view-transition-name: nav-logo;"
					/>
				</nav>
			</header>

			<main class="w-full grid content-start min-h-0 max-w-lg mx-auto gap-6">
				<h1 class="font-black text-3xl border-l-2 pl-3 border-l-cyan-500">
					Sign in
				</h1>
				<form id="login-form" class="grid gap-6" aria-label="Sign in form">
					<fieldset class="grid gap-4 border-none p-0 m-0">
						<div class="grid gap-1.5">
							<label
								for="email"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Email address
							</label>
							<input
								type="email"
								id="email"
								name="email"
								autocomplete="email"
								required
								placeholder="you@example.com"
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
						</div>

						<div class="grid gap-1.5">
							<label
								for="password"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Password
							</label>
							<input
								type="password"
								id="password"
								name="password"
								autocomplete="current-password"
								required
								placeholder="••••••••"
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
						</div>
					</fieldset>

					<button
						type="submit"
						id="login-submit"
						class="bg-cyan-700 text-neutral-50 px-6 py-3 font-bold hover:bg-cyan-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
					>
						Sign in
					</button>
				</form>
			</main>

			<Footer />
		</body>
	</Fragment>
</Shell>

<script>
	import { authClient } from "../lib/auth-client";

	const form = document.getElementById("login-form") as HTMLFormElement;
	const submitBtn = document.getElementById(
		"login-submit",
	) as HTMLButtonElement;

	form.addEventListener("submit", async (event) => {
		event.preventDefault();

		const data = new FormData(form);
		const email = (data.get("email") as string).trim();
		const password = data.get("password") as string;

		if (!email || !password) {
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = "Signing in…";

		const { error } = await authClient.signIn.email({
			email,
			password,
			rememberMe: true,
			callbackURL: "/dash",
		});

		if (error) {
			submitBtn.disabled = false;
			submitBtn.textContent = "Sign in";
		}
	});
</script>
