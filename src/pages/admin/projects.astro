---
export const prerender = false;

import { actions, isInputError } from "astro:actions";
import LogoWithTextVertical from "../../assets/logoWithTextVertical.svg";
import Button from "../../components/Button.astro";
import Footer from "../../components/Footer.astro";
import LogoutButton from "../../components/LogoutButton.astro";
import Shell from "../../layouts/Shell.astro";

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (session.user.role !== "admin") {
	return Astro.redirect("/dash");
}

const createProjectResult = Astro.getActionResult(actions.createProject);
const updateProjectResult = Astro.getActionResult(actions.updateProject);
const deleteProjectResult = Astro.getActionResult(actions.deleteProject);

const createInputErrors = isInputError(createProjectResult?.error)
	? createProjectResult.error.fields
	: {};
const updateInputErrors = isInputError(updateProjectResult?.error)
	? updateProjectResult.error.fields
	: {};

if (
	(createProjectResult && !createProjectResult.error) ||
	(updateProjectResult && !updateProjectResult.error) ||
	(deleteProjectResult && !deleteProjectResult.error)
) {
	return Astro.redirect("/admin/projects", 303);
}

function formatDateForInput(date: Date | null | undefined): string {
	if (!date) return "";
	return date.toISOString().slice(0, 10);
}

function formatDateDisplay(date: Date | null | undefined): string {
	if (!date) return "";
	return date.toLocaleDateString();
}

const organizationGroups = await Astro.locals.db.query.organization.findMany({
	columns: {
		id: true,
		name: true,
	},
	with: {
		projects: {
			columns: {
				id: true,
				name: true,
				deadline: true,
				stateOfWork: true,
				stateOfPayment: true,
				budget: true,
			},
			orderBy: {
				name: "asc",
			},
		},
	},
	orderBy: {
		name: "asc",
	},
});
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Admin Projects</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<nav class="grid grid-cols-[1fr_auto_1fr] w-full items-center">
					<LogoWithTextVertical
						class="h-10"
						style="view-transition-name: nav-logo;"
					/>
					<section class="justify-self-end col-start-3">
						<LogoutButton />
					</section>
				</nav>
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<a href="/admin">Back to Admin Overview</a>

				<section class="grid grid-cols-[1fr_auto] items-start gap-4">
					<h1 class="font-black text-3xl border-l-2 pl-3 border-l-cyan-500">
						Admin Projects
					</h1>
					<Button
						type="button"
						command="show-modal"
						commandfor="project-modal"
						disabled={organizationGroups.length === 0}
					>
						Add
					</Button>
				</section>

				{organizationGroups.length === 0 && (
						<p class="border border-dashed border-neutral-200 dark:border-neutral-800 p-4 text-sm text-neutral-600 dark:text-neutral-400">
							Create an organization before adding projects.
						</p>
					)}

				<section
					aria-labelledby="projects-list-heading"
					class="grid content-start gap-3"
				>
					{updateProjectResult?.error && (
							<p
								role="alert"
								class="border border-dashed border-red-300 dark:border-red-900 bg-red-50 dark:bg-red-950/40 px-3 py-2 text-sm text-red-700 dark:text-red-300"
							>
								Unable to update project. Please try again later.
							</p>
						)}
					{deleteProjectResult?.error && (
							<p
								role="alert"
								class="border border-dashed border-red-300 dark:border-red-900 bg-red-50 dark:bg-red-950/40 px-3 py-2 text-sm text-red-700 dark:text-red-300"
							>
								Unable to delete project. Please try again later.
							</p>
						)}
					<h2
						id="projects-list-heading"
						class="text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400"
					>
						Projects
					</h2>
					{organizationGroups.some(({ projects }) => projects.length > 0) ? (
							<ul class="grid gap-3">
								{organizationGroups.map((organizationRecord) =>
									organizationRecord.projects.map((projectRecord) => (
										<li class="grid gap-3 border border-dashed border-neutral-200 dark:border-neutral-800 p-4 sm:grid-cols-[1fr_auto] sm:items-center">
											<article class="grid gap-1">
												<h3 class="font-semibold">{projectRecord.name}</h3>
												<p class="text-sm text-neutral-600 dark:text-neutral-400">
													{organizationRecord.name}
												</p>
												{projectRecord.deadline || projectRecord.stateOfWork || projectRecord.stateOfPayment || projectRecord.budget != null ? (
													<dl class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-0.5 text-sm text-neutral-600 dark:text-neutral-400">
														{projectRecord.deadline && (
															<>
																<dt class="font-medium">Deadline</dt>
																<dd>{formatDateDisplay(projectRecord.deadline)}</dd>
															</>
														)}
														{projectRecord.stateOfWork && (
															<>
																<dt class="font-medium">Work</dt>
																<dd>{projectRecord.stateOfWork}</dd>
															</>
														)}
														{projectRecord.stateOfPayment && (
															<>
																<dt class="font-medium">Payment</dt>
																<dd>{projectRecord.stateOfPayment}</dd>
															</>
														)}
														{projectRecord.budget != null && (
															<>
																<dt class="font-medium">Budget</dt>
																<dd>{projectRecord.budget}</dd>
															</>
														)}
													</dl>
												) : null}
											</article>
											<div class="grid grid-flow-col gap-2 justify-self-start sm:justify-self-end">
												<Button
													type="button"
												data-action="edit-project"
													data-id={projectRecord.id}
													data-name={projectRecord.name}
													data-deadline={formatDateForInput(projectRecord.deadline)}
													data-state-of-work={projectRecord.stateOfWork || ""}
													data-state-of-payment={projectRecord.stateOfPayment || ""}
													data-budget={projectRecord.budget ?? ""}
												>
													Edit
												</Button>
												<form
													method="post"
													action={actions.deleteProject}
													class="grid"
													data-confirm="Are you sure you want to delete this project?"
												>
													<input
														type="hidden"
														name="projectId"
														value={projectRecord.id}
													/>
													<Button type="submit">Delete</Button>
												</form>
											</div>
										</li>
									)),
								)}
							</ul>
						) : (
							<p class="border border-dashed border-neutral-200 dark:border-neutral-800 p-4 text-sm text-neutral-600 dark:text-neutral-400">
								No projects yet.
							</p>
						)}
				</section>
			</main>

			<dialog
				id="project-modal"
				open={Boolean(createProjectResult?.error)}
				class="fixed inset-y-0 right-0 left-auto m-0 h-dvh max-h-dvh w-full max-w-xl overflow-hidden rounded-none border-l border-dashed border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-950 dark:text-neutral-50 p-0 shadow-2xl backdrop:bg-neutral-950/40 backdrop:backdrop-blur-[1px]"
			>
				<form
					method="post"
					action={actions.createProject}
					class="grid grid-rows-[auto_1fr_auto] h-full"
				>
					<header
						class="grid grid-cols-[1fr_auto] items-center border-b border-dashed border-neutral-200 dark:border-neutral-800 px-6 py-4"
					>
						<h2 class="text-base font-semibold">New Project</h2>
						<Button type="button" command="close" commandfor="project-modal">
							X
						</Button>
					</header>

					<section
						class="min-h-0 overflow-y-auto px-6 py-6 grid content-start gap-5"
					>
						{createProjectResult?.error && (
								<p
									role="alert"
									class="border border-dashed border-red-300 dark:border-red-900 bg-red-50 dark:bg-red-950/40 px-3 py-2 text-sm text-red-700 dark:text-red-300"
								>
									Unable to create project. Please check the fields and try again.
									{createProjectResult?.error}
								</p>
							)}

						<div class="grid gap-1.5">
							<label
								for="create-name"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Project name
							</label>
							<input
								type="text"
								id="create-name"
								name="name"
								required
								maxlength="120"
								aria-describedby={createInputErrors.name ? "create-name-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{createInputErrors.name && (
									<p id="create-name-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.name.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="create-organizationId"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Organization
							</label>
							<select
								id="create-organizationId"
								name="organizationId"
								required
								disabled={organizationGroups.length === 0}
								aria-describedby={createInputErrors.organizationId
										? "create-organizationId-error"
										: undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors"
							>
								<option value="" disabled selected
									>Select an organization</option
								>
								{organizationGroups.map((organizationRecord) => (
										<option
											value={organizationRecord.id}
										>
											{organizationRecord.name}
										</option>
									))}
							</select>
							{createInputErrors.organizationId && (
									<p
										id="create-organizationId-error"
										class="text-sm text-red-700 dark:text-red-300"
									>
										{createInputErrors.organizationId.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="create-deadline"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Deadline
							</label>
							<input
								type="date"
								id="create-deadline"
								name="deadline"
								aria-describedby={createInputErrors.deadline ? "create-deadline-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600 dark:[color-scheme:dark]"
							>
							{createInputErrors.deadline && (
									<p id="create-deadline-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.deadline.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="create-stateOfWork"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								State of work
							</label>
							<input
								type="text"
								id="create-stateOfWork"
								name="stateOfWork"
								aria-describedby={createInputErrors.stateOfWork ? "create-stateOfWork-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{createInputErrors.stateOfWork && (
									<p id="create-stateOfWork-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.stateOfWork.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="create-stateOfPayment"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								State of payment
							</label>
							<input
								type="text"
								id="create-stateOfPayment"
								name="stateOfPayment"
								aria-describedby={createInputErrors.stateOfPayment ? "create-stateOfPayment-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{createInputErrors.stateOfPayment && (
									<p id="create-stateOfPayment-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.stateOfPayment.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="create-budget"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								budget
							</label>
							<input
								type="number"
								id="create-budget"
								name="budget"
								min="0"
								step="1"
								aria-describedby={createInputErrors.budget ? "create-budget-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{createInputErrors.budget && (
									<p id="create-budget-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.budget.join(", ")}
									</p>
								)}
						</div>
						<div class="grid gap-1.5">
							<label
								for="create-deadline"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Deadline
							</label>
							<input
								type="date"
								id="create-createdAt"
								name="createdAt"
								aria-describedby={createInputErrors.createdAt ? "create-createdAt-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600 dark:[color-scheme:dark]"
								value={new Date().toISOString().slice(0, 10)}
							>
							{createInputErrors.createdAt && (
									<p id="create-createdAt-error" class="text-sm text-red-700 dark:text-red-300">
										{createInputErrors.createdAt.join(", ")}
									</p>
								)}
						</div>
					</section>

					<footer
						class="grid grid-flow-col justify-end gap-3 border-t border-dashed border-neutral-200 dark:border-neutral-800 px-6 py-4"
					>
						<Button type="submit" disabled={organizationGroups.length === 0}>
							Create Project
						</Button>
					</footer>
				</form>
			</dialog>

			<dialog
				id="edit-project-modal"
				class="fixed inset-y-0 right-0 left-auto m-0 h-dvh max-h-dvh w-full max-w-xl overflow-hidden rounded-none border-l border-dashed border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-950 dark:text-neutral-50 p-0 shadow-2xl backdrop:bg-neutral-950/40 backdrop:backdrop-blur-[1px]"
			>
				<form
					method="post"
					action={actions.updateProject}
					class="grid grid-rows-[auto_1fr_auto] h-full"
				>
					<header
						class="grid grid-cols-[1fr_auto] items-center border-b border-dashed border-neutral-200 dark:border-neutral-800 px-6 py-4"
					>
						<h2 class="text-base font-semibold">Edit Project</h2>
						<Button
							type="button"
							command="close"
							commandfor="edit-project-modal"
						>
							X
						</Button>
					</header>

					<section
						class="min-h-0 overflow-y-auto px-6 py-6 grid content-start gap-5"
					>
						<input type="hidden" name="projectId" id="edit-projectId">

						<div class="grid gap-1.5">
							<label
								for="edit-name"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Project name
							</label>
							<input
								type="text"
								id="edit-name"
								name="name"
								required
								maxlength="120"
								aria-describedby={updateInputErrors.name ? "edit-name-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{updateInputErrors.name && (
									<p id="edit-name-error" class="text-sm text-red-700 dark:text-red-300">
										{updateInputErrors.name.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="edit-deadline"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Deadline
							</label>
							<input
								type="date"
								id="edit-deadline"
								name="deadline"
								aria-describedby={updateInputErrors.deadline ? "edit-deadline-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600 dark:[color-scheme:dark]"
							>
							{updateInputErrors.deadline && (
									<p id="edit-deadline-error" class="text-sm text-red-700 dark:text-red-300">
										{updateInputErrors.deadline.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="edit-stateOfWork"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								State of work
							</label>
							<input
								type="text"
								id="edit-stateOfWork"
								name="stateOfWork"
								aria-describedby={updateInputErrors.stateOfWork ? "edit-stateOfWork-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{updateInputErrors.stateOfWork && (
									<p id="edit-stateOfWork-error" class="text-sm text-red-700 dark:text-red-300">
										{updateInputErrors.stateOfWork.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="edit-stateOfPayment"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								State of payment
							</label>
							<input
								type="text"
								id="edit-stateOfPayment"
								name="stateOfPayment"
								aria-describedby={updateInputErrors.stateOfPayment ? "edit-stateOfPayment-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{updateInputErrors.stateOfPayment && (
									<p id="edit-stateOfPayment-error" class="text-sm text-red-700 dark:text-red-300">
										{updateInputErrors.stateOfPayment.join(", ")}
									</p>
								)}
						</div>

						<div class="grid gap-1.5">
							<label
								for="edit-budget"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								budget
							</label>
							<input
								type="number"
								id="edit-budget"
								name="budget"
								min="0"
								step="1"
								aria-describedby={updateInputErrors.budget ? "edit-budget-error" : undefined}
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
							{updateInputErrors.budget && (
									<p id="edit-budget-error" class="text-sm text-red-700 dark:text-red-300">
										{updateInputErrors.budget.join(", ")}
									</p>
								)}
						</div>
					</section>

					<footer
						class="grid grid-flow-col justify-end gap-3 border-t border-dashed border-neutral-200 dark:border-neutral-800 px-6 py-4"
					>
						<Button type="submit"> Update Project </Button>
					</footer>
				</form>
			</dialog>
			<Footer />
		</body>
	</Fragment>
</Shell>

<script>
	const deleteForms = document.querySelectorAll("form[data-confirm]");
	deleteForms.forEach((form) => {
		if (form instanceof HTMLFormElement) {
			form.addEventListener("submit", (event) => {
				event.preventDefault();
				if (window.confirm(form.dataset.confirm)) {
					form.submit();
				}
			});
		}
	});

	document
		.querySelectorAll<HTMLElement>("[data-action='edit-project']")
		.forEach((btn) => {
			btn.addEventListener("click", () => {
				const modal = document.getElementById("edit-project-modal");
				if (!(modal instanceof HTMLDialogElement)) return;

				const projectIdInput =
					modal.querySelector<HTMLInputElement>("#edit-projectId");
				const nameInput = modal.querySelector<HTMLInputElement>("#edit-name");
				const deadlineInput =
					modal.querySelector<HTMLInputElement>("#edit-deadline");
				const stateOfWorkInput =
					modal.querySelector<HTMLInputElement>("#edit-stateOfWork");
				const stateOfPaymentInput = modal.querySelector<HTMLInputElement>(
					"#edit-stateOfPayment",
				);
				const budgetInput =
					modal.querySelector<HTMLInputElement>("#edit-budget");

				if (projectIdInput) projectIdInput.value = btn.dataset.id || "";
				if (nameInput) nameInput.value = btn.dataset.name || "";
				if (deadlineInput) deadlineInput.value = btn.dataset.deadline || "";
				if (stateOfWorkInput)
					stateOfWorkInput.value = btn.dataset.stateOfWork || "";
				if (stateOfPaymentInput)
					stateOfPaymentInput.value = btn.dataset.stateOfPayment || "";
				if (budgetInput) budgetInput.value = btn.dataset.budget || "";

				modal.showModal();
			});
		});
</script>
