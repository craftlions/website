---
export const prerender = false;

import { actions } from "astro:actions";
import Badge from "../../components/Badge.astro";
import Button from "../../components/Button.astro";
import Footer from "../../components/Footer.astro";
import Nav from "../../components/Nav.astro";
import Shell from "../../layouts/Shell.astro";
import { getUuidV7Date } from "../../lib/uuid.ts";

const onboardResult = Astro.getActionResult(actions.onboardOrganization);

if (onboardResult && !onboardResult.error) {
	return Astro.redirect("/admin");
}

const organizations = await Astro.locals.db.query.organization.findMany({
	columns: {
		id: true,
		name: true,
		slug: true,
	},
	with: {
		data: {
			columns: {
				yearlyBudget: true,
			},
		},
		projects: {
			columns: {
				id: true,
				name: true,
				state: true,
			},
			with: {
				phases: {
					columns: {
						id: true,
						title: true,
						cost: true,
						currency: true,
						state: true,
						dueAt: true,
					},
					with: {
						invoice: {
							columns: {
								id: true,
								invoiceNumber: true,
								total: true,
								stripeStatus: true,
								fetchedAt: true,
							},
						},
					},
				},
			},
			orderBy: {
				name: "asc",
			},
		},
	},
	orderBy: {
		name: "asc",
	},
});

const now = new Date();
const currencyFormatter = new Intl.NumberFormat("de-DE", {
	style: "currency",
	currency: "EUR",
});
const daysSince = (id: string) => {
	const date = getUuidV7Date(id);
	return date
		? Math.max(0, Math.floor((now.getTime() - date.getTime()) / 86400000))
		: 0;
};

const queue = organizations
	.flatMap((organization) =>
		organization.projects.flatMap((project) =>
			project.phases.flatMap((phase) => {
				const link = `/admin/org/${organization.id}`;

				if (phase.state === "invoiced" && phase.dueAt && phase.dueAt < now) {
					return [
						{
							priority: 0,
							kind: "Overdue",
							client: organization.name,
							label: `${project.name} · ${phase.invoice?.invoiceNumber ?? phase.title}`,
							amount: phase.invoice?.total ?? phase.cost,
							days: daysSince(phase.invoice?.id ?? phase.id),
							link,
						},
					];
				}

				if (phase.state === "submitted") {
					return [
						{
							priority: 1,
							kind: "To plan",
							client: organization.name,
							label: `${project.name} · ${phase.title}`,
							amount: phase.cost,
							days: daysSince(phase.id),
							link,
						},
					];
				}

				if (phase.state === "planned") {
					return [
						{
							priority: 2,
							kind: "Awaiting client",
							client: organization.name,
							label: `${project.name} · ${phase.title}`,
							amount: phase.cost,
							days: daysSince(phase.id),
							link,
						},
					];
				}

				if (phase.state === "invoiced") {
					return [
						{
							priority: 3,
							kind: "Unpaid",
							client: organization.name,
							label: `${project.name} · ${phase.invoice?.invoiceNumber ?? phase.title}`,
							amount: phase.invoice?.total ?? phase.cost,
							days: daysSince(phase.invoice?.id ?? phase.id),
							link,
						},
					];
				}

				return [];
			}),
		),
	)
	.toSorted((a, b) => a.priority - b.priority || b.days - a.days);

const ledger = organizations.map((organization) => {
	const activeProjects = organization.projects.filter(
		(project) => project.state === "active",
	).length;
	const totalProjects = organization.projects.length;
	const openInvoices = organization.projects
		.flatMap((project) => project.phases)
		.filter((phase) => phase.state === "invoiced")
		.reduce((total, phase) => total + (phase.invoice?.total ?? phase.cost), 0);
	const planned = organization.projects
		.flatMap((project) => project.phases)
		.filter((phase) => phase.state === "planned").length;
	const submitted = organization.projects
		.flatMap((project) => project.phases)
		.filter((phase) => phase.state === "submitted").length;
	const overdue = organization.projects
		.flatMap((project) => project.phases)
		.filter(
			(phase) => phase.state === "invoiced" && phase.dueAt && phase.dueAt < now,
		).length;

	return {
		...organization,
		activeProjects,
		totalProjects,
		openInvoices,
		planned,
		submitted,
		overdue,
		budgetUsage:
			organization.data?.yearlyBudget && organization.data.yearlyBudget > 0
				? (openInvoices / organization.data.yearlyBudget) * 100
				: null,
	};
});
const outstandingTotal = ledger.reduce(
	(total, organization) => total + organization.openInvoices,
	0,
);
---

<Shell>
	<Fragment slot="head"><title>craftlions | Admin</title></Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] gap-6 bg-neutral-50 p-4 text-pretty text-neutral-950 antialiased dark:bg-neutral-950 dark:text-neutral-50"
		>
			<header class="grid w-full max-w-5xl gap-6 mx-auto">
				<Nav />
			</header>
			<main class="grid w-full max-w-5xl content-start gap-8 mx-auto">
				<section class="grid gap-4">
					<div class="grid gap-1">
						<p
							class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
							>Admin</p
						>
						<h1
							class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
							>Client workbench</h1
						>
					</div>
					<form
						method="POST"
						action={actions.onboardOrganization}
						class="grid gap-3 border border-dashed border-neutral-300 p-4 dark:border-neutral-700 md:grid-cols-2"
					>
						<label class="grid gap-1 text-sm">
							<span class="font-medium">Contact email</span>
							<input
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 dark:border-neutral-700"
								name="email"
								type="email"
								required
							>
						</label>
						<label class="grid gap-1 text-sm">
							<span class="font-medium">Contact name</span>
							<input
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 dark:border-neutral-700"
								name="name"
								required
							>
						</label>
						<label class="grid gap-1 text-sm">
							<span class="font-medium">Organization</span>
							<input
								id="organization-name"
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 dark:border-neutral-700"
								name="organizationName"
								required
							>
						</label>
						<label class="grid gap-1 text-sm">
							<span class="font-medium">Slug</span>
							<input
								id="organization-slug"
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 dark:border-neutral-700"
								name="slug"
								required
							>
						</label>
						<label class="grid gap-1 text-sm md:col-span-2">
							<span class="font-medium">Yearly budget</span>
							<input
								class="border border-dashed border-neutral-300 bg-transparent px-3 py-2 dark:border-neutral-700"
								name="yearlyBudget"
								type="number"
								min="1"
							>
						</label>
						{onboardResult?.error && <p class="text-sm text-red-700 dark:text-red-300 md:col-span-2">{onboardResult.error.message}</p>}
						<div class="grid md:col-span-2">
							<Button type="submit">Onboard client</Button>
						</div>
					</form>
				</section>

				<section class="grid gap-3" aria-labelledby="queue-heading">
					<h2
						id="queue-heading"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>Needs action</h2
					>
					<div
						class="grid border border-dashed border-neutral-300 dark:border-neutral-700"
					>
						{queue.length > 0 ? queue.map((item) => (
							<article class="grid gap-3 border-b border-dashed border-neutral-300 p-4 last:border-b-0 dark:border-neutral-700 md:grid-cols-[auto_1fr_auto_auto] md:items-center">
								<Badge type={item.priority === 0 ? "error" : "info"}>{item.kind}</Badge>
								<div class="grid gap-1">
									<h3 class="font-medium">{item.client}</h3>
									<p class="text-sm text-neutral-600 dark:text-neutral-400">{item.label}</p>
								</div>
								<p class="text-sm tabular-nums">{currencyFormatter.format(item.amount)}</p>
								<div class="grid grid-flow-col items-center gap-3">
									<p class="text-sm text-neutral-600 dark:text-neutral-400">{item.days}d</p>
									<Button href={item.link}>Open</Button>
								</div>
							</article>
						)) : (
							<p class="p-4 text-sm text-neutral-600 dark:text-neutral-400">Nothing needs action.</p>
						)}
					</div>
				</section>

				<section class="grid gap-3" aria-labelledby="ledger-heading">
					<h2
						id="ledger-heading"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>Client ledger</h2
					>
					<div
						class="overflow-x-auto border border-dashed border-neutral-300 dark:border-neutral-700"
					>
						<table class="w-full min-w-4xl border-collapse text-left text-sm">
							<thead>
								<tr
									class="border-b border-dashed border-neutral-300 text-xs uppercase text-neutral-500 dark:border-neutral-700 dark:text-neutral-400"
								>
									<th class="px-4 py-3" scope="col">Client</th>
									<th class="px-4 py-3" scope="col">Attention</th>
									<th class="px-4 py-3" scope="col">Projects</th>
									<th class="px-4 py-3" scope="col">Budget</th>
									<th class="px-4 py-3 text-right" scope="col">Open</th>
									<th class="px-4 py-3" scope="col">Action</th>
								</tr>
							</thead>
							<tbody>
								{ledger.length > 0 ? ledger.map((organization) => (
									<tr class:list={["border-b border-dashed border-neutral-300 last:border-b-0 dark:border-neutral-700", organization.openInvoices === 0 && organization.planned === 0 && organization.submitted === 0 && "opacity-60"]}>
										<td class="px-4 py-4 font-medium">{organization.name}</td>
										<td class="px-4 py-4">
											<div class="grid grid-flow-col justify-start gap-2">
												{organization.overdue > 0 && <Badge type="error">Overdue</Badge>}
												{organization.submitted > 0 && <Badge type="info">To plan</Badge>}
												{organization.planned > 0 && <Badge type="info">Awaiting</Badge>}
												{organization.overdue === 0 && organization.submitted === 0 && organization.planned === 0 && <span class="text-neutral-500 dark:text-neutral-400">Quiet</span>}
											</div>
										</td>
										<td class="px-4 py-4 tabular-nums">{organization.activeProjects}/{organization.totalProjects}</td>
										<td class="px-4 py-4">
											{organization.budgetUsage === null ? (
												<span class="text-neutral-500 dark:text-neutral-400">No budget</span>
											) : (
												<div class="grid gap-1">
													<progress class:list={["h-2 w-36 appearance-none border border-dashed border-neutral-300 bg-transparent [&::-webkit-progress-bar]:bg-transparent [&::-webkit-progress-value]:bg-neutral-900 [&::-moz-progress-bar]:bg-neutral-900 dark:border-neutral-700 dark:[&::-webkit-progress-value]:bg-neutral-100 dark:[&::-moz-progress-bar]:bg-neutral-100", organization.budgetUsage > 100 && "[&::-webkit-progress-value]:bg-red-700 [&::-moz-progress-bar]:bg-red-700 dark:[&::-webkit-progress-value]:bg-red-400 dark:[&::-moz-progress-bar]:bg-red-400"]} max="100" value={Math.min(organization.budgetUsage, 100)} />
													<span class:list={["text-xs tabular-nums", organization.budgetUsage > 100 && "text-red-700 dark:text-red-300"]}>{organization.budgetUsage.toFixed(1)}%</span>
												</div>
											)}
										</td>
										<td class="px-4 py-4 text-right tabular-nums">{currencyFormatter.format(organization.openInvoices)}</td>
										<td class="px-4 py-4"><Button href={`/admin/org/${organization.id}`}>Open</Button></td>
									</tr>
								)) : (
									<tr>
										<td class="px-4 py-4 text-neutral-600 dark:text-neutral-400" colspan="6">No clients yet.</td>
									</tr>
								)}
							</tbody>
							<tfoot>
								<tr
									class="border-t border-dashed border-neutral-300 font-semibold dark:border-neutral-700"
								>
									<td class="px-4 py-3" colspan="4">Outstanding</td>
									<td class="px-4 py-3 text-right tabular-nums"
										>{currencyFormatter.format(outstandingTotal)}</td
									>
									<td class="px-4 py-3"></td>
								</tr>
							</tfoot>
						</table>
					</div>
				</section>
			</main>
			<Footer />
			<script>
				const organizationName =
					document.querySelector<HTMLInputElement>("#organization-name");
				const organizationSlug =
					document.querySelector<HTMLInputElement>("#organization-slug");
				let slugEdited = false;

				organizationSlug?.addEventListener("input", () => {
					slugEdited = true;
				});
				organizationName?.addEventListener("input", () => {
					if (!organizationSlug || slugEdited) return;
					organizationSlug.value = organizationName.value
						.trim()
						.toLowerCase()
						.replace(/[^a-z0-9]+/g, "-")
						.replace(/^-|-$/g, "");
				});
			</script>
		</body>
	</Fragment>
</Shell>
