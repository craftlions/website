---
export const prerender = false;

// import { Octokit } from "@octokit/rest";
import { isAPIError } from "better-auth/api";
import Button from "../../../../../components/Button.astro";
import Footer from "../../../../../components/Footer.astro";
import PhasesTable from "../../../../../components/PhasesTable.astro";
import Nav from "../../../../../components/Nav.astro";
import ProjectInvoices from "../../../../../components/ProjectInvoices.astro";
import Shell from "../../../../../layouts/Shell.astro";

const { publicId, slug } = Astro.params;

if (!publicId || !slug) {
	return Astro.redirect("/dash");
}

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const project = await Astro.locals.db.query.projects.findFirst({
	columns: {
		name: true,
	},
	with: {
		events: {
			columns: {
				id: true,
				publicId: true,
				aggregateType: true,
				event: true,
			},
			orderBy: {
				id: "desc",
			},
		},
		phases: {
			columns: {
				title: true,
				dueAt: true,
				cost: true,
				currency: true,
				state: true,
			},
			with: {
				events: {
					columns: {
						id: true,
						publicId: true,
						aggregateType: true,
						event: true,
					},
					orderBy: {
						id: "desc",
					},
				},
			},
			orderBy: {
				dueAt: "asc",
			},
		},
		invoices: {
			columns: {
				id: true,
				invoiceNumber: true,
				stripePaymentPage: true,
			},
			orderBy: {
				id: "desc",
			},
		},
	},
	where: {
		publicId,
		organizationId: organization.id,
	},
});

if (!project) {
	return Astro.redirect(`/dash/org/${slug}`);
}

const events = [
	...project.events,
	...project.phases.flatMap((phase) => phase.events),
].toSorted((a, b) => b.id.localeCompare(a.id));

const formatEventType = (eventType: string) =>
	eventType
		.split(".")
		.pop()
		?.replaceAll("_", " ")
		.replace(/\b\w/g, (c) => c.toUpperCase()) ?? eventType;

