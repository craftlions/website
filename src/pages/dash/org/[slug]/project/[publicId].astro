---

<Shell>
	<Fragment slot="head"> <title>craftlions | {project.name}</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<Button href={`/dash/org/${slug}`}>Back to Dashboard</Button>

				<section class="grid gap-4">
					<p
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Project Overview
					</p>
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						{project.name}
					</h1>
				</section>

				<section>
					<h2
						id="phases"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Phases
					</h2>
					<PhasesTable phases={project.phases} />
				</section>

				<section>
					<h2
						id="invoices"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Invoices
					</h2>
					<ProjectInvoices invoices={project.invoices} />
				</section>

				<section class="grid gap-4">
					<h2
						id="event-log"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Event Log
					</h2>
					{events.length > 0 ? (
						<ol class="grid" aria-label="Project event log">
							{events.map((ev, i) => (
								<li class="grid grid-cols-[1rem_1fr] gap-x-3">
									<div class="grid grid-rows-[auto_1fr] justify-items-center" aria-hidden="true">
										<span class="mt-2.5 h-1.5 w-1.5 shrink-0 border border-neutral-400 bg-transparent dark:border-neutral-500" />
										{i < events.length - 1 && (
											<span class="border-l border-dashed border-neutral-300 dark:border-neutral-700" />
										)}
									</div>
									<div class="grid gap-1 pb-5">
											<div class="grid grid-cols-[1fr_auto] items-center gap-2">
												<p class="text-sm font-medium text-neutral-900 dark:text-neutral-100">
													{formatEventType(ev.event)}
												</p>
												<span class="inline-grid w-max place-items-center whitespace-nowrap border border-dashed border-neutral-300 bg-transparent px-2 py-0.5 text-xs/none font-semibold capitalize text-neutral-500 dark:border-neutral-700 dark:text-neutral-400">
													{ev.aggregateType}
												</span>
											</div>
											<p class="text-xs text-neutral-500 dark:text-neutral-400">
												{ev.publicId}
											</p>
										</div>
									</li>
								))}
						</ol>
					) : (
						<p class="border border-dashed border-neutral-300 bg-transparent p-4 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-400">
							No events have been recorded yet.
						</p>
					)}
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
