---
export const prerender = false;

import { actions } from "astro:actions";
import { isAPIError } from "better-auth/api";
import Button from "../../../../../components/Button.astro";
import Footer from "../../../../../components/Footer.astro";
import Nav from "../../../../../components/Nav.astro";
import PhasesTable from "../../../../../components/PhasesTable.astro";
import ProjectInvoices from "../../../../../components/ProjectInvoices.astro";
import Shell from "../../../../../layouts/Shell.astro";

const { publicId, slug } = Astro.params;

if (!publicId || !slug) {
	return Astro.redirect("/dash");
}

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const approveResult = Astro.getActionResult(actions.approvePhase);
const declineResult = Astro.getActionResult(actions.declinePhase);

if (
	(approveResult && !approveResult.error) ||
	(declineResult && !declineResult.error)
) {
	return Astro.redirect(Astro.url.pathname);
}

const project = await Astro.locals.db.query.projects.findFirst({
	columns: {
		id: true,
		name: true,
	},
	with: {
		phases: {
			columns: {
				publicId: true,
				title: true,
				dueAt: true,
				cost: true,
				currency: true,
				state: true,
				externalUrl: true,
			},
			with: {},
			orderBy: {
				dueAt: "asc",
				id: "asc",
			},
		},
	},
	where: {
		publicId,
		organizationId: organization.id,
	},
});

if (!project) {
	return Astro.redirect(`/dash/org/${slug}`);
}

const currentMember = await Astro.locals.db.query.member.findFirst({
	columns: {
		role: true,
	},
	where: {
		organizationId: organization.id,
		userId: session.user.id,
	},
});
const canApprovePhases =
	currentMember?.role === "owner" || currentMember?.role === "admin";
---

<Shell>
	<Fragment slot="head"> <title>craftlions | {project.name}</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<Button href={`/dash/org/${slug}`}>Back to Dashboard</Button>

				<section class="grid gap-4">
					<p
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Project Overview
					</p>
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						{project.name}
					</h1>
				</section>

				<section>
					<h2
						id="phases"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Phases
					</h2>
					<PhasesTable
						phases={project.phases}
						canApprovePhases={canApprovePhases}
					/>
				</section>

				<section>
					<h2
						id="invoices"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Invoices
					</h2>
					<ProjectInvoices id={project.id} />
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
