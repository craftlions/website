---
export const prerender = false;

// import { Octokit } from "@octokit/rest";
import { isAPIError } from "better-auth/api";
import Button from "../../../../../components/Button.astro";
import Footer from "../../../../../components/Footer.astro";
import MilestoneTable from "../../../../../components/MilestoneTable.astro";
import Nav from "../../../../../components/Nav.astro";
import ProjectInvoices from "../../../../../components/ProjectInvoices.astro";
import Shell from "../../../../../layouts/Shell.astro";

const { id, slug } = Astro.params;

if (!id || !slug) {
	return Astro.redirect("/dash");
}

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const project = await Astro.locals.db.query.project.findFirst({
	columns: {
		id: true,
		name: true,
	},
	with: {
		events: {
			columns: {
				aggregateType: true,
				eventType: true,
				payload: true,
				recordedAt: true,
			},
		},
		milestones: {
			columns: {
				title: true,
				dueAt: true,
				cost: true,
				currency: true,
				state: true,
			},
			with: {
				events: {
					columns: {
						aggregateType: true,
						eventType: true,
						payload: true,
						recordedAt: true,
					},
				},
			},
			orderBy: {
				dueAt: "asc",
			},
		},
	},
	where: {
		id: id,
		organizationId: organization.id,
	},
});

if (!project) {
	return Astro.redirect(`/dash/org/${slug}`);
}

type ChangeRecord = Record<string, { from: unknown; to: unknown }>;

const events = [
	...project.events,
	...project.milestones.flatMap((m) => m.events),
]
	.sort((a, b) => b.recordedAt.getTime() - a.recordedAt.getTime())
	.map((ev) => {
		const payload = ev.payload as Record<string, unknown> | null;
		const changes = payload?.changes as ChangeRecord | undefined;
		return {
			...ev,
			changeEntries: changes
				? Object.entries(changes)
				: ([] as Array<[string, { from: unknown; to: unknown }]>),
		};
	});

const dateTimeFormatter = new Intl.DateTimeFormat("de-DE", {
	dateStyle: "medium",
	timeStyle: "short",
});

const formatEventType = (eventType: string) =>
	eventType
		.split(".")
		.pop()
		?.replaceAll("_", " ")
		.replace(/\b\w/g, (c) => c.toUpperCase()) ?? eventType;

