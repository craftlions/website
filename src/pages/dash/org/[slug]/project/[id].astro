---
export const prerender = false;

import { Octokit } from "@octokit/rest";
import { isAPIError } from "better-auth/api";
import Button from "../../../../../components/Button.astro";
import Footer from "../../../../../components/Footer.astro";
import Nav from "../../../../../components/Nav.astro";
import ProjectInvoices from "../../../../../components/ProjectInvoices.astro";
import Shell from "../../../../../layouts/Shell.astro";

const { id, slug } = Astro.params;

if (!id || !slug) {
	return Astro.redirect("/dash");
}

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const project = await Astro.locals.db.query.project.findFirst({
	columns: {
		id: true,
		name: true,
		budget: true,
		deadline: true,
		stateOfWork: true,
		stateOfPayment: true,
		createdAt: true,
		updatedAt: true,
	},
	where: {
		id,
		organizationId: organization.id,
	},
});

if (!project) {
	return Astro.redirect(`/dash/org/${slug}`);
}

const currencyFormatter = new Intl.NumberFormat("de-DE", {
	style: "currency",
	currency: "EUR",
});

function formatDateDisplay(date: Date | null | undefined): string {
	if (!date) return "-";
	return date.toLocaleDateString();
}

let githubIssue = null;
let githubIssueError = "";

try {
	const githubAccess = await Astro.locals.auth.api.getAccessToken({
		body: {
			providerId: "github",
		},
		headers: Astro.request.headers,
	});

	if (githubAccess.accessToken) {
		const response = await new Octokit({
			auth: githubAccess.accessToken,
		}).rest.issues.get({
			owner: "frickegroup",
			repo: "orga",
			issue_number: 2186,
			headers: {
				accept: "application/vnd.github.full+json",
			},
		});

		githubIssue = response.data;
	} else {
		githubIssueError = "Link a GitHub account to view the project issue.";
	}
} catch {
	githubIssueError = "Unable to load the project issue from GitHub.";
}
---

<Shell>
	<Fragment slot="head"> <title>craftlions | {project.name}</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<a href={`/dash/org/${slug}`}>
					<Button type="button"> Back to Dashboard </Button>
				</a>

				<section class="grid gap-4">
					<p
						class="text-sm font-semibold uppercase text-cyan-700 dark:text-cyan-400"
					>
						Project Overview
					</p>
					<h1 class="font-black text-3xl border-l-2 pl-3 border-l-cyan-500">
						{project.name}
					</h1>
				</section>

				<section>
					<h2
						id="invoices"
						class="text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400"
						>Invoices</h2
					>
					<ProjectInvoices id={project.id} />
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
