---

<Shell>
	<Fragment slot="head"> <title>craftlions | {project.name}</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<Button href={`/dash/org/${slug}`}>Back to Dashboard</Button>

				<section class="grid gap-4">
					<p
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Project Overview
					</p>
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						{project.name}
					</h1>
				</section>

				<section>
					<h2
						id="milestones"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Milestones
					</h2>
					<MilestoneTable milestones={project.milestones} />
				</section>

				<section>
					<h2
						id="invoices"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Invoices
					</h2>
					<ProjectInvoices id={project.id} />
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
