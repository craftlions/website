---
export const prerender = false;

import type { projectSelectType } from "../../../lib/schema.ts";
import { isAPIError } from "better-auth/api";
import Badge from "../../../components/Badge.astro";
import Button from "../../../components/Button.astro";
import Footer from "../../../components/Footer.astro";
import Nav from "../../../components/Nav.astro";
import OrganizationInvoices from "../../../components/OrganizationInvoices.astro";
import Shell from "../../../layouts/Shell.astro";
import { getUuidV7Date } from "../../../lib/uuid.ts";

const { slug } = Astro.params;

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const organizationData = await Astro.locals.db.query.organization.findFirst({
	columns: {
		id: true,
	},
	with: {
		data: {
			columns: {
				yearlyBudget: true,
			},
		},
		projects: {
			columns: {
				publicId: true,
				name: true,
				state: true,
			},
			with: {
				phases: {
					columns: {
						cost: true,
					},
				},
				invoices: {
					columns: {
						id: true,
						total: true,
					},
				},
			},
			orderBy: {
				name: "asc",
			},
		},
	},
	where: {
		id: organization.id,
	},
});

const now = new Date();
const startOfYear = new Date(now.getFullYear(), 0, 1);
const startOfNextYear = new Date(now.getFullYear() + 1, 0, 1);
const projects =
	organizationData?.projects.map((project) => ({
		publicId: project.publicId,
		name: project.name,
		state: project.state,
		cost:
			project.phases.length > 0
				? project.phases.reduce((total, phase) => total + phase.cost, 0)
				: null,
	})) ?? [];
const completedProjectCount = projects.filter(
	(project) => project.state === "completed",
).length;
const activeProjectCount = projects.filter(
	(project) => project.state === "active",
).length;
const totalInvoicedAmount =
	organizationData?.projects
		.flatMap((project) => project.invoices)
		.reduce((total, invoice) => {
			const createdAt = getUuidV7Date(invoice.id);

			if (
				!createdAt ||
				createdAt < startOfYear ||
				createdAt >= startOfNextYear
			) {
				return total;
			}

			return total + invoice.total;
		}, 0) ?? 0;
const yearlyBudget = organizationData?.data?.yearlyBudget ?? 0;
const remainingBudget = yearlyBudget - totalInvoicedAmount;
const budgetUsagePercentage =
	yearlyBudget > 0 ? (totalInvoicedAmount / yearlyBudget) * 100 : 0;
const budgetPacePercentage = ((now.getMonth() + 1) / 12) * 100;
const budgetStatus =
	yearlyBudget <= 0
		? "Budget not set"
		: remainingBudget < 0
			? "Over yearly budget"
			: budgetUsagePercentage > budgetPacePercentage
				? "Ahead of calendar pace"
				: "Within calendar pace";
const budgetPaceGridLineClass = [
	"col-start-2",
	"col-start-3",
	"col-start-4",
	"col-start-5",
	"col-start-6",
	"col-start-7",
	"col-start-8",
	"col-start-9",
	"col-start-10",
	"col-start-11",
	"col-start-12",
	"col-start-13",
][now.getMonth()];

const currencyFormatter = new Intl.NumberFormat("de-DE", {
	style: "currency",
	currency: "EUR",
});

const projectStateToBadgeType = (projectState: projectSelectType["state"]) => {
	switch (projectState) {
		case "completed":
			return "success";
		case "active":
			return "info";
		case "archived":
		case "draft":
			return "gray";
		default:
			return "info";
	}
};
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Dashboard</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<section class="grid grid-cols-[1fr_auto] items-start gap-4">
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						{organization.name}'s Dashboard
					</h1>
				</section>

				<section
					aria-labelledby="overview-heading"
					class="grid content-start gap-4"
				>
					<div class="grid gap-1">
						<h2
							id="overview-heading"
							class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>
							Overview
						</h2>
						<p class="max-w-2xl text-sm text-neutral-600 dark:text-neutral-400">
							Budget and project state for the current calendar year.
						</p>
					</div>
					<div
						class="grid border border-dashed border-neutral-300 bg-transparent dark:border-neutral-700"
					>
						<dl class="grid sm:grid-cols-2">
							<div
								class="grid gap-1 border-b border-dashed border-neutral-300 p-4 dark:border-neutral-700 sm:border-r"
							>
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Yearly budget
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{yearlyBudget > 0 ? currencyFormatter.format(yearlyBudget) : "-"}
								</dd>
							</div>
							<div
								class="grid gap-1 border-b border-dashed border-neutral-300 p-4 dark:border-neutral-700"
							>
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Invoiced this year
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{currencyFormatter.format(totalInvoicedAmount)}
								</dd>
							</div>
							<div
								class="grid gap-1 border-b border-dashed border-neutral-300 p-4 dark:border-neutral-700 sm:border-r"
							>
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Used
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{yearlyBudget > 0 ? `${budgetUsagePercentage.toFixed(1)}%` : "-"}
								</dd>
							</div>
							<div
								class="grid gap-1 border-b border-dashed border-neutral-300 p-4 dark:border-neutral-700"
							>
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Remaining
								</dt>
								<dd
									class:list={[
										"text-xl font-semibold tabular-nums",
										yearlyBudget > 0 &&
											remainingBudget < 0 &&
											"text-red-700 dark:text-red-300",
									]}
								>
									{yearlyBudget > 0
										? currencyFormatter.format(remainingBudget)
										: "-"}
								</dd>
							</div>
						</dl>
						<div class="grid gap-4 p-4">

							<div class="grid gap-2">
								<div
									class="grid grid-cols-[1fr_auto] items-end gap-3 text-sm"
								>
									<label
										for="budget-progress"
										class="font-medium text-neutral-800 dark:text-neutral-200"
									>
										Budget use
									</label>
									<p
										class:list={[
							  				"tabular-nums text-neutral-600 dark:text-neutral-400",
							  				yearlyBudget > 0 &&
							  					budgetUsagePercentage > 100 &&
							  					"text-red-700 dark:text-red-300",
							  			]}
									>
										{yearlyBudget > 0 ? `${budgetUsagePercentage.toFixed(1)}%` : "No budget"}
									</p>
								</div>
								<div class="relative grid">
									<progress
										id="budget-progress"
										max="100"
										value={yearlyBudget > 0
							  				? Math.min(budgetUsagePercentage, 100)
							  				: 0}
										class:list={[
							  				"h-2 w-full appearance-none border border-dashed border-neutral-300 bg-transparent [&::-webkit-progress-bar]:bg-transparent [&::-webkit-progress-value]:bg-neutral-900 [&::-moz-progress-bar]:bg-neutral-900 dark:border-neutral-700 dark:[&::-webkit-progress-value]:bg-neutral-100 dark:[&::-moz-progress-bar]:bg-neutral-100",
							  				yearlyBudget > 0 &&
							  					budgetUsagePercentage > 100 &&
							  					"[&::-webkit-progress-value]:bg-red-700 [&::-moz-progress-bar]:bg-red-700 dark:[&::-webkit-progress-value]:bg-red-400 dark:[&::-moz-progress-bar]:bg-red-400",
							  			]}
									>
										{yearlyBudget > 0
							  				? `${budgetUsagePercentage.toFixed(1)}% used`
							  				: "No yearly budget set"}
									</progress>
									{yearlyBudget > 0 && (
							  				<span
							  					aria-hidden="true"
							  					class="pointer-events-none absolute -inset-y-1 left-0 grid w-full grid-cols-12"
							  				>
							  					<span
							  						class:list={[
							  							"h-full w-0.75 justify-self-start border-x border-neutral-50 bg-neutral-950 dark:border-neutral-950 dark:bg-neutral-50",
							  							budgetPaceGridLineClass,
							  						]}
							  					/>
							  				</span>
							  			)}
								</div>
								<p class="text-sm text-neutral-600 dark:text-neutral-400">
									{yearlyBudget > 0
							  			? `Based on invoices created this calendar year. The marker shows ${budgetPacePercentage.toFixed(1)}% calendar pace.`
							  			: "Set a yearly budget to compare invoices against calendar pace."}
								</p>
							</div>

							<dl
								class="grid gap-3 border-t border-dashed border-neutral-300 pt-4 text-sm dark:border-neutral-700 sm:grid-cols-3"
							>
								<div class="grid gap-1">
									<dt class="text-neutral-500 dark:text-neutral-400">
										Budget status
									</dt>
									<dd
										class:list={[
											"font-medium",
											yearlyBudget > 0 &&
												remainingBudget < 0 &&
												"text-red-700 dark:text-red-300",
										]}
									>
										{budgetStatus}
									</dd>
								</div>
								<div class="grid gap-1">
									<dt class="text-neutral-500 dark:text-neutral-400">
										Active projects
									</dt>
									<dd class="font-medium tabular-nums">{activeProjectCount}</dd>
								</div>
								<div class="grid gap-1">
									<dt class="text-neutral-500 dark:text-neutral-400">
										Completed projects
									</dt>
									<dd class="font-medium tabular-nums"
										>{completedProjectCount}</dd
									>
								</div>
							</dl>
						</div>
					</div>
				</section>

				<section
					aria-labelledby="projects-list-heading"
					class="group grid content-start gap-3"
				>
					<div class="grid grid-cols-[1fr_auto] items-center gap-3">
						<h2
							id="projects-list-heading"
							class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>
							Projects
						</h2>
						{completedProjectCount > 0 && (
							<label
								class="grid cursor-pointer grid-flow-col items-center gap-2 text-sm text-neutral-600 select-none dark:text-neutral-400"
							>
								<input
									type="checkbox"
									class="size-4 cursor-pointer appearance-none border border-dashed border-neutral-400 bg-transparent checked:bg-neutral-900 checked:bg-[length:0.75rem] checked:bg-center checked:bg-no-repeat focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-neutral-700 checked:bg-[url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20viewBox=%220%200%2016%2016%22%20fill=%22none%22%20stroke=%22white%22%20stroke-width=%222%22%3E%3Cpath%20d=%22M3%208l3.5%203.5L13%205%22/%3E%3C/svg%3E')] dark:border-neutral-600 dark:checked:bg-neutral-100 dark:focus-visible:outline-neutral-300 dark:checked:bg-[url('data:image/svg+xml,%3Csvg%20xmlns=%22http://www.w3.org/2000/svg%22%20viewBox=%220%200%2016%2016%22%20fill=%22none%22%20stroke=%22black%22%20stroke-width=%222%22%3E%3Cpath%20d=%22M3%208l3.5%203.5L13%205%22/%3E%3C/svg%3E')]"
								/>
								<span>Hide completed</span>
							</label>
						)}
					</div>
					<table
						class="w-full text-sm border border-dashed border-neutral-300 dark:border-neutral-700"
					>
						<thead class="text-neutral-700 dark:text-neutral-300">
							<tr>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Name
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Status
								</th>
								<th scope="col" class="text-right font-semibold px-4 py-3">
									Total Cost
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Actions
								</th>
							</tr>
						</thead>
						<tbody
							class="divide-y divide-dashed divide-neutral-300 dark:divide-neutral-700"
						>
							{projects.length > 0 ? (
									projects.map((project) => (
										<tr
											class:list={[
												project.state === "completed" &&
													"opacity-55 group-has-[:checked]:hidden",
											]}
										>
											<th scope="row" class="px-4 py-3 text-left font-medium">
												{project.name}
											</th>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400">
												<Badge type={projectStateToBadgeType(project.state)}>
										{project.state ?? "-"}
									</Badge>
											</td>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400 text-right">
												{project.cost !== null
													? currencyFormatter.format(project.cost)
													: "-"}
											</td>
												<td class="px-4 py-3">
													<Button
														href={`/dash/org/${slug}/project/${project.publicId}`}
													>
													Details
												</Button>
											</td>
										</tr>
									))
								) : (
									<tr>
										<td
											colspan="4"
											class="px-4 py-6 text-center text-neutral-600 dark:text-neutral-400"
										>
											No projects yet.
										</td>
									</tr>
								)}
							{projects.length > 0 && completedProjectCount === projects.length && (
									<tr class="hidden group-has-[:checked]:table-row">
										<td
											colspan="4"
											class="px-4 py-6 text-center text-neutral-600 dark:text-neutral-400"
										>
											All projects are completed and currently hidden.
										</td>
									</tr>
								)}
						</tbody>
					</table>
				</section>
				<section>
					<h2
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>Invoices</h2
					>
					<OrganizationInvoices id={organization.id} />
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
