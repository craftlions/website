---
export const prerender = false;

import { actions } from "astro:actions";
import { isAPIError } from "better-auth/api";
import { and, asc, eq, gte, inArray, lt, sum } from "drizzle-orm";
import Button from "../../../components/Button.astro";
import Footer from "../../../components/Footer.astro";
import Nav from "../../../components/Nav.astro";
import OrganizationInvoices from "../../../components/OrganizationInvoices.astro";
import Shell from "../../../layouts/Shell.astro";
import { invoice, milestone, project } from "../../../lib/schema.ts";

const { slug } = Astro.params;

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const updateMetadataResult = Astro.getActionResult(
	actions.mutateOrganizationMetadata,
);

if (updateMetadataResult && !updateMetadataResult.error) {
	return Astro.redirect(`/dash/org/${slug}`, 303);
}

const projects = await Astro.locals.db
	.select({
		id: project.id,
		name: project.name,
		deadline: project.deadline,
		stateOfWork: project.stateOfWork,
		stateOfPayment: project.stateOfPayment,
		cost: Astro.locals.db
			.select({ value: sum(milestone.cost).mapWith(Number).as("value") })
			.from(milestone)
			.where(eq(milestone.projectId, project.id))
			.as("cost"),
	})
	.from(project)
	.where(eq(project.organizationId, organization.id))
	.orderBy(asc(project.name));

const metadata = await Astro.locals.db.query.organizationMetadata.findFirst({
	where: { organizationId: organization.id },
});

const projectIds = projects.map((p) => p.id);
const totalInvoicedAmount =
	projectIds.length > 0
		? await Astro.locals.db
				.select({ total: sum(invoice.total) })
				.from(invoice)
				.where(
					and(
						inArray(invoice.projectId, projectIds),
						gte(invoice.createdAt, new Date(new Date().getFullYear(), 0, 1)),
						lt(invoice.createdAt, new Date(new Date().getFullYear() + 1, 0, 1)),
					),
				)
				.then((result) => Number(result[0]?.total ?? 0))
		: 0;
const yearlyBudget = metadata?.yearlyBudget ?? 0;
const budgetUsagePercentage =
	yearlyBudget > 0 ? (totalInvoicedAmount / yearlyBudget) * 100 : 0;

const currencyFormatter = new Intl.NumberFormat("de-DE", {
	style: "currency",
	currency: "EUR",
});
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Dashboard</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<Nav organizationSlug={slug} />
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<section class="grid grid-cols-[1fr_auto] items-start gap-4">
					<h1
						class="border-l border-dashed border-neutral-400 pl-3 text-3xl font-semibold leading-tight dark:border-neutral-600"
					>
						{organization.name}'s Dashboard
					</h1>
				</section>

				<section
					aria-labelledby="overview-heading"
					class="grid content-start gap-3"
				>
					<h2
						id="overview-heading"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Overview
					</h2>
					<div
						class="grid gap-4 border border-dashed border-neutral-300 bg-transparent p-4 dark:border-neutral-700"
					>
						<dl class="grid gap-4 sm:grid-cols-2">
							<div class="grid gap-1">
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Yearly budget
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{yearlyBudget > 0 ? currencyFormatter.format(yearlyBudget) : "-"}
								</dd>
							</div>
							<div class="grid gap-1">
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Invoiced this year
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{currencyFormatter.format(totalInvoicedAmount)}
								</dd>
							</div>
							<div class="grid gap-1">
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Used
								</dt>
								<dd class="text-xl font-semibold tabular-nums">
									{yearlyBudget > 0 ? `${budgetUsagePercentage.toFixed(1)}%` : "-"}
								</dd>
							</div>
							<div class="grid gap-1">
								<dt
									class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400"
								>
									Remaining
								</dt>
								<dd
									class:list={[
										"text-xl font-semibold tabular-nums",
										yearlyBudget > 0 &&
											yearlyBudget - totalInvoicedAmount < 0 &&
											"text-red-700 dark:text-red-300",
									]}
								>
									{yearlyBudget > 0
										? currencyFormatter.format(yearlyBudget - totalInvoicedAmount)
										: "-"}
								</dd>
							</div>
						</dl>
						<div
							class="grid gap-2 border-t border-dashed border-neutral-300 pt-4 dark:border-neutral-700"
						>
							<div class="grid grid-cols-[1fr_auto] items-end gap-3 text-sm">
								<label
									for="budget-progress"
									class="font-medium text-neutral-800 dark:text-neutral-200"
								>
									Budget use
								</label>
								<p
									class:list={[
										"tabular-nums text-neutral-600 dark:text-neutral-400",
										yearlyBudget > 0 &&
											budgetUsagePercentage > 100 &&
											"text-red-700 dark:text-red-300",
									]}
								>
									{yearlyBudget > 0 ? `${budgetUsagePercentage.toFixed(1)}%` : "No budget"}
								</p>
							</div>
							<progress
								id="budget-progress"
								max="100"
								value={yearlyBudget > 0
									? Math.min(budgetUsagePercentage, 100)
									: 0}
								class:list={[
									"h-2 w-full appearance-none border border-dashed border-neutral-300 bg-transparent [&::-webkit-progress-bar]:bg-transparent [&::-webkit-progress-value]:bg-neutral-900 [&::-moz-progress-bar]:bg-neutral-900 dark:border-neutral-700 dark:[&::-webkit-progress-value]:bg-neutral-100 dark:[&::-moz-progress-bar]:bg-neutral-100",
									yearlyBudget > 0 &&
										budgetUsagePercentage > 100 &&
										"[&::-webkit-progress-value]:bg-red-700 [&::-moz-progress-bar]:bg-red-700 dark:[&::-webkit-progress-value]:bg-red-400 dark:[&::-moz-progress-bar]:bg-red-400",
								]}
							>
								{yearlyBudget > 0
									? `${budgetUsagePercentage.toFixed(1)}% used`
									: "No yearly budget set"}
							</progress>
							<p class="text-sm text-neutral-600 dark:text-neutral-400">
								{yearlyBudget > 0
									? "Based on invoices created this calendar year."
									: "No yearly budget has been set."}
							</p>
						</div>
					</div>
				</section>

				<section
					aria-labelledby="projects-list-heading"
					class="grid content-start gap-3"
				>
					<h2
						id="projects-list-heading"
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
					>
						Projects
					</h2>
					<table
						class="w-full text-sm border border-dashed border-neutral-300 dark:border-neutral-700"
					>
						<thead class="text-neutral-700 dark:text-neutral-300">
							<tr>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Name
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Status
								</th>
								<th scope="col" class="text-right font-semibold px-4 py-3">
									Cost
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Actions
								</th>
							</tr>
						</thead>
						<tbody
							class="divide-y divide-dashed divide-neutral-300 dark:divide-neutral-700"
						>
							{projects.length > 0 ? (
									projects.map((project) => (
										<tr>
											<th scope="row" class="px-4 py-3 text-left font-medium">
												{project.name}
											</th>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400">
												{project.stateOfWork ?? "-"}
											</td>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400 text-right">
												{project.cost !== null
													? currencyFormatter.format(project.cost)
													: "-"}
											</td>
											<td class="px-4 py-3">
												<Button
													href={`/dash/org/${slug}/project/${project.id}`}
												>
													Details
												</Button>
											</td>
										</tr>
									))
								) : (
									<tr>
										<td
											colspan="4"
											class="px-4 py-6 text-center text-neutral-600 dark:text-neutral-400"
										>
											No projects yet.
										</td>
									</tr>
								)}
						</tbody>
					</table>
				</section>
				<section>
					<h2
						class="text-sm font-semibold uppercase text-neutral-500 dark:text-neutral-400"
						>Invoices</h2
					>
					<OrganizationInvoices id={organization.id} />
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
