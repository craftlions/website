---
export const prerender = false;

import { actions, isInputError } from "astro:actions";
import { isAPIError } from "better-auth/api";
import LogoWithTextVertical from "../../../assets/logoWithTextVertical.svg";
import Button from "../../../components/Button.astro";
import Footer from "../../../components/Footer.astro";
import LogoutButton from "../../../components/LogoutButton.astro";
import Shell from "../../../layouts/Shell.astro";

const { slug } = Astro.params;

const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}

if (!session.session.activeOrganizationId) {
	try {
		await Astro.locals.auth.api.setActiveOrganization({
			body: {
				organizationSlug: slug,
			},
			headers: Astro.request.headers,
		});
	} catch (error) {
		if (isAPIError(error) && error.body?.code === "ORGANIZATION_NOT_FOUND") {
			return Astro.redirect("/dash");
		}
	}
}

const organization = await Astro.locals.auth.api.getFullOrganization({
	query: {
		organizationSlug: slug,
		membersLimit: 0,
	},
	headers: Astro.request.headers,
});

if (!organization) {
	return Astro.redirect("/dash");
}

const updateMetadataResult = Astro.getActionResult(
	actions.mutateOrganizationMetadata,
);
const metadataInputErrors = isInputError(updateMetadataResult?.error)
	? updateMetadataResult.error.fields
	: {};

if (updateMetadataResult && !updateMetadataResult.error) {
	return Astro.redirect(`/dash/org/${slug}`, 303);
}

const projects = await Astro.locals.db.query.project.findMany({
	columns: {
		id: true,
		name: true,
		budget: true,
		deadline: true,
		stateOfWork: true,
		stateOfPayment: true,
	},
	where: { organizationId: organization.id },
	orderBy: { name: "asc" },
});

const metadata = await Astro.locals.db.query.organizationMetadata.findFirst({
	where: { organizationId: organization.id },
});

const totalBudget = metadata?.yearlyBudget ?? 0;

const totalProjectBudget = projects.reduce(
	(sum, project) => sum + (project.budget ?? 0),
	0,
);

const currencyFormatter = new Intl.NumberFormat("de-DE", {
	style: "currency",
	currency: "EUR",
});
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Dashboard</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-6 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-3xl mx-auto w-full">
				<nav class="grid grid-cols-[1fr_auto_1fr] w-full items-center">
					<LogoWithTextVertical
						class="h-10"
						style="view-transition-name: nav-logo;"
					/>
					<section class="justify-self-end col-start-3">
						<LogoutButton />
					</section>
				</nav>
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-6"
			>
				<section class="grid grid-cols-[1fr_auto] items-start gap-4">
					<h1 class="font-black text-3xl border-l-2 pl-3 border-l-cyan-500">
						{organization.name}'s Dashboard
					</h1>
				</section>

				<section
					aria-labelledby="projects-list-heading"
					class="grid content-start gap-3"
				>
					<h2
						id="projects-list-heading"
						class="text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400"
					>
						Projects
					</h2>
					<table
						class="w-full text-sm border border-dashed border-neutral-200 dark:border-neutral-800"
					>
						<thead
							class="bg-neutral-100 dark:bg-neutral-900 text-neutral-700 dark:text-neutral-300"
						>
							<tr>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Name
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Status
								</th>
								<th scope="col" class="text-right font-semibold px-4 py-3">
									Budget
								</th>
								<th scope="col" class="text-left font-semibold px-4 py-3">
									Actions
								</th>
							</tr>
						</thead>
						<tbody
							class="divide-y divide-dashed divide-neutral-200 dark:divide-neutral-800"
						>
							{projects.length > 0 ? (
									projects.map((project) => (
										<tr>
											<th scope="row" class="px-4 py-3 text-left font-medium">
												{project.name}
											</th>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400">
												{project.stateOfWork ?? "-"}
											</td>
											<td class="px-4 py-3 text-neutral-600 dark:text-neutral-400 text-right">
												{project.budget != null
													? currencyFormatter.format(project.budget)
													: "-"}
											</td>
											<td class="px-4 py-3">
												<a
													href={`/dash/org/${slug}/project/${project.id}`}
												>
													<Button type="button" disabled>Details</Button>
												</a>
											</td>
										</tr>
									))
								) : (
									<tr>
										<td
											colspan="4"
											class="px-4 py-6 text-center text-neutral-600 dark:text-neutral-400"
										>
											No projects yet.
										</td>
									</tr>
								)}
						</tbody>
						<tfoot
							class="border-t border-dashed border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 font-semibold text-neutral-900 dark:text-neutral-100"
						>
							<tr>
								<td colspan="2"></td>
								<th scope="col" class="px-4 py-3 text-right">Sum</th>
								<th scope="col" class="px-4 py-3 text-left">Yearly Budget</th>
							</tr>
							<tr>
								<th colspan="2" scope="row" class="px-4 py-3 text-left">
									Total
								</th>
								<td
									class="px-4 py-3 text-right"
									class:list={[
										{
											"text-red-700 dark:text-red-400":
												totalProjectBudget > totalBudget,
											"text-green-700 dark:text-green-400":
												totalProjectBudget <= totalBudget,
										},
									]}
								>
									{currencyFormatter.format(totalProjectBudget)}
								</td>
								<td class="px-4 py-3">
									<details
										class="grid justify-items-start gap-2"
										open={Boolean(updateMetadataResult?.error)}
									>
										<summary
											class="grid cursor-pointer list-none justify-items-start [&::-webkit-details-marker]:hidden"
										>
											<span
												class="grid grid-flow-col auto-cols-max items-center gap-2"
											>
												<span>{currencyFormatter.format(totalBudget)}</span>
												<span
													class="px-3 py-1 border transition-colors border-dashed rounded cursor-pointer border-neutral-200 hover:bg-neutral-200 hover:border-neutral-400 text-neutral-900 dark:border-neutral-800 dark:hover:bg-neutral-800 dark:hover:border-neutral-600 dark:text-neutral-100"
												>
													Edit
												</span>
											</span>
										</summary>
										<form
											method="post"
											action={actions.mutateOrganizationMetadata}
											class="mt-2 grid justify-items-start gap-2"
										>
											<input
												type="hidden"
												name="organizationId"
												value={organization.id}
											>
											<label for="yearly-budget" class="sr-only">
												Yearly budget
											</label>
											<span
												class="grid grid-flow-col auto-cols-max items-start gap-2"
											>
												<input
													type="number"
													id="yearly-budget"
													name="yearlyBudget"
													min="1"
													step="1"
													value={metadata?.yearlyBudget ?? ""}
													aria-describedby={metadataInputErrors.yearlyBudget
														? "yearly-budget-error"
														: undefined}
													class="w-32 bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-1 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
												>
												<Button type="submit">Save</Button>
											</span>
											{metadataInputErrors.yearlyBudget && (
												<p
													id="yearly-budget-error"
													class="max-w-56 text-sm font-normal text-red-700 dark:text-red-300"
												>
													{metadataInputErrors.yearlyBudget.join(", ")}
												</p>
											)}
											{updateMetadataResult?.error &&
												!metadataInputErrors.yearlyBudget && (
													<p class="max-w-56 text-sm font-normal text-red-700 dark:text-red-300">
														Unable to update yearly budget.
													</p>
												)}
										</form>
									</details>
								</td>
							</tr>
						</tfoot>
					</table>
				</section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>
