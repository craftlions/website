---
export const prerender = false;

import LogoWithTextVertical from "../assets/logoWithTextVertical.svg";
import Footer from "../components/Footer.astro";
import Shell from "../layouts/Shell.astro";
const session = await Astro.locals.auth.api.getSession({
	headers: Astro.request.headers,
});

if (session) {
	return Astro.redirect("/");
}

const token = Astro.url.searchParams.get("token");
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Reset Password</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-12 p-4 text-pretty"
		>
			<header class="grid gap-6 justify-items-center max-w-3xl mx-auto">
				<nav class="py-6 grid grid-cols-1 w-full">
					<LogoWithTextVertical
						class="h-28"
						style="view-transition-name: nav-logo;"
					/>
				</nav>
			</header>

			<main class="w-full grid content-start min-h-0 max-w-lg mx-auto gap-6">
				<h1 class="font-black text-3xl border-l-2 pl-3 border-l-cyan-500">
					New password
				</h1>
				<p class="text-neutral-600 dark:text-neutral-400 text-sm">
					Enter a new password below.
				</p>
				<form
					id="reset-form"
					class="grid gap-6"
					aria-label="Reset password form"
					data-token={token}
				>
					<fieldset class="grid gap-4 border-none p-0 m-0">
						<div class="grid gap-1.5">
							<label
								for="password"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								New password
							</label>
							<input
								type="password"
								id="password"
								name="password"
								autocomplete="new-password"
								required
								minlength={8}
								placeholder="••••••••"
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
						</div>

						<div class="grid gap-1.5">
							<label
								for="confirm-password"
								class="text-sm font-semibold text-neutral-700 dark:text-neutral-300"
							>
								Confirm password
							</label>
							<input
								type="password"
								id="confirm-password"
								name="confirm-password"
								autocomplete="new-password"
								required
								minlength={8}
								placeholder="••••••••"
								class="bg-transparent border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm outline-none focus:border-cyan-500 transition-colors placeholder:text-neutral-400 dark:placeholder:text-neutral-600"
							>
						</div>
					</fieldset>

					<button
						type="submit"
						id="reset-submit"
						class="bg-cyan-700 text-neutral-50 px-6 py-3 font-bold hover:bg-cyan-800 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
					>
						Reset password
					</button>
				</form>

				<p
					id="reset-message"
					class="text-sm hidden"
					role="status"
					aria-live="polite"
				> </p>
			</main>

			<Footer />
		</body>
	</Fragment>
</Shell>

<script>
	import { authClient } from "../lib/auth-client";

	const form = document.getElementById("reset-form") as HTMLFormElement;
	const submitBtn = document.getElementById(
		"reset-submit",
	) as HTMLButtonElement;
	const message = document.getElementById(
		"reset-message",
	) as HTMLParagraphElement;
	const token = form.dataset.token;

	if (!token) {
		form.style.display = "none";
		message.textContent =
			"Invalid or missing reset token. Please request a new reset link.";
		message.className = "text-sm text-red-600 dark:text-red-400";
	}

	form.addEventListener("submit", async (event) => {
		event.preventDefault();

		const data = new FormData(form);
		const password = data.get("password") as string;
		const confirmPassword = data.get("confirm-password") as string;

		if (!password || !confirmPassword) {
			return;
		}

		if (password !== confirmPassword) {
			message.textContent = "Passwords do not match.";
			message.className = "text-sm text-red-600 dark:text-red-400";
			return;
		}

		if (!token) {
			message.textContent = "Invalid or missing reset token.";
			message.className = "text-sm text-red-600 dark:text-red-400";
			return;
		}

		submitBtn.disabled = true;
		submitBtn.textContent = "Resetting…";

		const { error } = await authClient.resetPassword({
			newPassword: password,
			token,
		});

		if (error) {
			submitBtn.disabled = false;
			submitBtn.textContent = "Reset password";
			message.textContent =
				error.message || "Something went wrong. Please try again.";
			message.className = "text-sm text-red-600 dark:text-red-400";
		} else {
			form.style.display = "none";
			message.textContent =
				"Your password has been reset. Redirecting to sign in…";
			message.className = "text-sm text-green-700 dark:text-green-400";
			setTimeout(() => {
				window.location.href = "/login";
			}, 2000);
		}
	});
</script>
