---
export const prerender = false;

import LogoWithTextVertical from "../assets/logoWithTextVertical.svg";
import Button from "../components/Button.astro";
import Footer from "../components/Footer.astro";
import Shell from "../layouts/Shell.astro";
import { auth } from "../lib/auth.ts";

const session = await auth.api.getSession({
	headers: await Astro.request.headers,
});

if (!session) {
	return Astro.redirect("/login");
}
---

<Shell>
	<Fragment slot="head"> <title>craftlions | Dashboard</title> </Fragment>
	<Fragment slot="body">
		<body
			class="min-h-dvh grid grid-rows-[auto_1fr_auto] bg-neutral-50 dark:bg-neutral-950 dark:text-neutral-50 text-neutral-950 antialiased gap-12 p-4 text-pretty"
		>
			<header class="grid gap-6 max-w-4xl mx-auto w-full">
				<nav class="grid grid-cols-[1fr_auto_1fr] w-full items-center">
					<LogoWithTextVertical
						class="h-10"
						style="view-transition-name: nav-logo;"
					/>
					<section class="justify-self-end col-start-3"
						><Button type="button" id="logout-button">Logout</Button></section
					>
				</nav>
			</header>

			<main
				class="w-full grid content-start min-h-0 pl-3 max-w-3xl mx-auto gap-12"
			>
				<section><p>DASHBOARD</p></section>
			</main>
			<Footer />
		</body>
	</Fragment>
</Shell>

<script>
	import { authClient } from "../lib/auth-client.ts";

	const logoutButton = document.getElementById("logout-button");
	if (logoutButton && logoutButton instanceof HTMLButtonElement) {
		logoutButton.addEventListener("click", async () => {
			await authClient.signOut({
				fetchOptions: {
					onSuccess: () => {
						// redirect and put into history
						window.location.href = "/";
					},
				},
			});
		});
	}
</script>
