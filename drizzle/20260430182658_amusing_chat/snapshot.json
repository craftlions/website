      "definition": "select \"aggregate_id\" as \"id\", \"payload\"->>'project_id' as \"project_id\", \"payload\"->>'invoice_number' as \"invoice_number\", \"payload\"->>'stripe_id' as \"stripe_id\", \"payload\"->>'stripe_payment_page' as \"stripe_payment_page\", \"recorded_at\" as \"created_at\", (\"payload\"->>'total')::numeric as \"total\" from \"event\" where \"event\".\"aggregate_type\" = 'invoice' AND \"event\".\"event_type\" = 'created'",
